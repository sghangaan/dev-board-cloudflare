{
  "name": "image-gallery-api",
  "main": "src/worker.js",
  "compatibility_date": "2024-01-01",
  // R2 bucket binding
  // Copy this file to wrangler.jsonc and replace with your actual bucket name
  "r2_buckets": [
    {
      "binding": "image_gallery_bucket",
      "bucket_name": "your-image-gallery-bucket-name"
    }
  ]
  // Note: Create the R2 bucket using:
  // wrangler r2 bucket create your-image-gallery-bucket-name
}
